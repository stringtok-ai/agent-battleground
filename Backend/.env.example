JWT_SECRET=change-this-to-a-long-random-string-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DEMO_AUTO_RUN=1
SEED_MODE=fast
